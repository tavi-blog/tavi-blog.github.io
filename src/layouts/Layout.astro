---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteTitle = 'Tavi';
const pageTitle = title === siteTitle ? siteTitle : `${title} · ${siteTitle}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <link rel="icon" href="data:," />
  </head>
  <body>
    <header>
      <nav>
        <a href="/">{siteTitle}</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} {siteTitle} &middot; <a href="/rss.xml">RSS</a></p>
    </footer>
    <style is:global>
      :root {
        --fg: #000;
        --bg: #fff;
        color-scheme: light;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --fg: #fff;
          --bg: #000;
          color-scheme: dark;
        }
      }

      * {
        box-sizing: border-box;
        border-radius: 0 !important;
        box-shadow: none !important;
        transition: none !important;
        animation: none !important;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
      }

      body {
        font-family:
          ui-monospace,
          'SF Mono',
          SFMono-Regular,
          Menlo,
          Consolas,
          'Liberation Mono',
          monospace;
        font-size: 1rem;
        line-height: 1.65;
      }

      a {
        color: var(--fg);
      }

      a:hover,
      a:focus {
        text-decoration: underline;
      }

      header,
      main,
      footer {
        max-width: 65ch;
        margin: 0 auto;
        padding-left: 1.5rem;
        padding-right: 1.5rem;
      }

      header {
        border-bottom: 1px solid var(--fg);
        padding-top: 2rem;
        padding-bottom: 1.5rem;
      }

      header nav a {
        text-decoration: none;
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: 0.02em;
      }

      main {
        padding-top: 3rem;
        padding-bottom: 3rem;
        min-height: 50vh;
      }

      footer {
        border-top: 1px solid var(--fg);
        padding-top: 1.5rem;
        padding-bottom: 2rem;
        font-size: 0.85rem;
      }

      h1,
      h2,
      h3 {
        line-height: 1.25;
      }

      img {
        max-width: 100%;
      }

      blockquote {
        margin: 1.5rem 0;
        padding-left: 1rem;
        border-left: 1px solid var(--fg);
      }

      pre {
        border: 1px solid var(--fg);
        padding: 1rem;
        overflow-x: auto;
      }

      code {
        font-family: inherit;
      }
    </style>
  </body>
</html>
