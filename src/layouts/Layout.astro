---
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/700.css';
import '@fontsource/ibm-plex-serif/400.css';
import '@fontsource/ibm-plex-serif/700.css';
import '@fontsource/ibm-plex-serif/400-italic.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteTitle = 'tavi-blog';
const pageTitle = title ? `${title} · ${siteTitle}` : siteTitle;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <link rel="icon" href="data:," />
  </head>
  <body>
    <header>
      <nav>
        <a href="/">{siteTitle}</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} {siteTitle} &middot; <a href="/rss.xml">RSS</a></p>
    </footer>
    <style is:global>
      :root {
        --fg: #000;
        --bg: #fff;
        --font-mono: 'IBM Plex Mono', monospace;
        --font-serif: 'IBM Plex Serif', Georgia, serif;
        color-scheme: light;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --fg: #fff;
          --bg: #000;
          color-scheme: dark;
        }
      }

      * {
        box-sizing: border-box;
        border-radius: 0 !important;
        box-shadow: none !important;
        transition: none !important;
        animation: none !important;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
      }

      body {
        font-family: var(--font-serif);
        font-size: 18px;
        line-height: 1.6;
      }

      a {
        color: var(--fg);
      }

      a:hover,
      a:focus {
        text-decoration: underline;
      }

      /* Fixed unit, not ch: header/footer are mono and main/body are serif,
         and ch is relative to each element's own font, so a font-relative
         unit here would make the top and bottom rules different widths.
         42rem approximates the original ~65ch reading measure. */
      header,
      main,
      footer {
        max-width: 42rem;
        margin: 0 auto;
        padding-left: 1.5rem;
        padding-right: 1.5rem;
      }

      header {
        border-bottom: 1px solid var(--fg);
        padding-top: 2rem;
        padding-bottom: 1.5rem;
      }

      header nav a {
        font-family: var(--font-mono);
        text-decoration: none;
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: 0.02em;
      }

      main {
        padding-top: 3rem;
        padding-bottom: 3rem;
        min-height: 50vh;
      }

      footer {
        font-family: var(--font-mono);
        border-top: 1px solid var(--fg);
        padding-top: 1.5rem;
        padding-bottom: 2rem;
        font-size: 1.1rem;
        font-weight: 700;
      }

      h1,
      h2,
      h3 {
        font-family: var(--font-mono);
        font-weight: 700;
        line-height: 1.15;
      }

      h1 {
        font-size: 2.25rem;
      }

      img {
        max-width: 100%;
      }

      blockquote {
        margin: 1.5rem 0;
        padding-left: 1rem;
        border-left: 1px solid var(--fg);
      }

      pre {
        border: 1px solid var(--fg);
        padding: 1rem;
        overflow-x: auto;
      }

      code {
        font-family: inherit;
      }
    </style>
  </body>
</html>
